{
  "name": "task-manager-mcp",
  "version": "1.0.0",
  "description": "MCP Server for Task Manager — connects Claude AI to your task database",
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "build": "npm install @prisma/client --no-save && node node_modules/prisma/build/index.js generate && node node_modules/typescript/bin/tsc",
    "start": "node dist/index.js",
    "dev": "tsc && node dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.2",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@types/express": "^5.0.6",
    "dotenv": "^16.4.5",
    "express": "^5.2.1",
    "pg": "^8.20.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "prisma": "^7.6.0",
    "typescript": "^5.4.5"
  }
}
