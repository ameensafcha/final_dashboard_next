generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())

  employees   Employee[]

  @@index([name])
  @@index([is_active])
  @@map("roles")
}

model Employee {
  id                     String           @id
  name                   String
  email                  String           @unique
  is_active              Boolean          @default(true)
  created_at             DateTime         @default(now())
  updated_at             DateTime         @updatedAt
  role_id                String?
  
  role                   Role?            @relation(fields: [role_id], references: [id], onDelete: SetNull)
  
  comments               task_comments[]
  time_logs              task_time_logs[]
  assigned_tasks         tasks[]          @relation("task_assignee")
  created_tasks          tasks[]          @relation("task_creator")
  notifications_received notifications[]  @relation("notification_recipient")
  notifications_sent     notifications[]  @relation("notification_actor")

  batches                batches[]
  transactions           transactions[]
  task_attachments       task_attachments[]
  daily_plans            DailyPlan[]      @relation("employee_daily_plans")

  @@index([email])
  @@index([role_id])
  @@index([is_active])
  @@map("employees")
}

model raw_materials {
  id           String                @id @default(uuid())
  name         String
  quantity     Float
  price_per_kg Float?
  unit         String                @default("kg")
  logs         raw_material_logs[]
  receivings   receiving_materials[]
  batches      batches[]
  
  @@index([name])
}

model receiving_materials {
  id              String        @id @default(uuid())
  raw_material_id String
  quantity        Float
  rate            Float?
  supplier        String
  date            DateTime      @default(now())
  notes           String?
  unit            String        @default("kg")
  raw_material    raw_materials @relation(fields: [raw_material_id], references: [id])

  @@index([raw_material_id])
  @@index([date(sort: Desc)])
}

model flavors {
  id                String              @id @default(uuid())
  name              String
  short_code        String              @default("XX")
  is_active         Boolean             @default(true)
  created_at        DateTime            @default(now())
  ingredients       String?
  batches           batches[]
  finished_products finished_products[]
  product_flavors   product_flavors[]
  variants          product_variants[]
}

model products {
  id              String             @id @default(uuid())
  name            String
  description     String?
  is_active       Boolean            @default(true)
  created_at      DateTime           @default(now())
  product_flavors product_flavors[]
  variants        product_variants[]
}

model product_variants {
  id            String                  @id @default(uuid())
  product_id    String
  size_id       String
  price         Float                   @default(0)
  sku           String                  @unique
  is_active     Boolean                 @default(false)
  created_at    DateTime                @default(now())
  description   String?
  flavor_id     String
  receive_items packing_receive_items[]
  flavor        flavors                 @relation(fields: [flavor_id], references: [id])
  product       products                @relation(fields: [product_id], references: [id], onDelete: Cascade)
  size          sizes                   @relation(fields: [size_id], references: [id])
  inventory     variant_inventory?
  stock         product_stock?

  @@unique([product_id, flavor_id, size_id])
  @@index([product_id])
  @@index([is_active])
}

model product_flavors {
  id         String   @id @default(uuid())
  product_id String
  flavor_id  String
  flavor     flavors  @relation(fields: [flavor_id], references: [id])
  product    products @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@unique([product_id, flavor_id])
}

model sizes {
  id         String             @id @default(uuid())
  size       String
  unit       String             @default("kg")
  pack_type  String
  is_active  Boolean            @default(true)
  created_at DateTime           @default(now())
  variants   product_variants[]
}

model transactions {
  id           String   @id @default(uuid())
  type         String
  amount       Float
  date         DateTime @default(now())
  reference_id String?
  
  person_id    String?   
  employee     Employee? @relation(fields: [person_id], references: [id])
  
  note         String?
  created_at   DateTime @default(now())

  @@index([type])
  @@index([date(sort: Desc)])
  @@index([person_id])
}

model batches {
  id              String   @id @default(uuid())
  batch_id        String   @unique
  date            DateTime @default(now())
  
  logged_by       String
  employee        Employee @relation(fields: [logged_by], references: [id])

  flavor_id       String
  leaves_in       Float
  powder_out      Float
  waste_loss      Float
  yield_percent   Float
  quality_check   Boolean  @default(false)
  status          String
  notes           String?
  created_at      DateTime @default(now())
  
  raw_material_id String?
  raw_material    raw_materials? @relation(fields: [raw_material_id], references: [id])
  
  flavor          flavors  @relation(fields: [flavor_id], references: [id])

  @@index([status])
  @@index([created_at(sort: Desc)])
  @@index([flavor_id])
  @@index([logged_by])
}

model raw_material_logs {
  id              String        @id @default(uuid())
  raw_material_id String
  quantity        Float
  type            String
  reference_id    String?
  created_at      DateTime      @default(now())
  raw_material    raw_materials @relation(fields: [raw_material_id], references: [id])

  @@index([raw_material_id])
  @@index([created_at(sort: Desc)])
}

model finished_products {
  id              String   @id @default(uuid())
  flavor_id       String
  quantity        Float
  batch_reference String?
  created_at      DateTime @default(now())
  flavor          flavors  @relation(fields: [flavor_id], references: [id])

  @@index([created_at(sort: Desc)])
  @@index([flavor_id])
}

model packing_logs {
  id               String   @id @default(uuid())
  third_party_name String
  bag_size         Int
  bag_count        Int
  total_kg         Float
  created_at       DateTime @default(now())

  @@index([created_at(sort: Desc)])
}

model raw_material_stock {
  id           String   @id
  name         String
  quantity     Float    @default(0)
  unit         String   @default("kg")
  price_per_kg Float?
  updated_at   DateTime @default(now())
}

model product_stock {
  variant_id String           @id
  quantity   Int              @default(0)
  updated_at DateTime         @default(now())
  variant    product_variants @relation(fields: [variant_id], references: [id], onDelete: Cascade)
}

model powder_stock {
  id                 Int      @id @default(autoincrement())
  received           Float    @default(0)
  sent               Float    @default(0)
  total_from_batches Float    @default(0)
  total_sent         Float    @default(0)
  available          Float    @default(0)
  updated_at         DateTime @default(now())
}

model packing_receives {
  id               String                  @id @default(uuid())
  third_party_name String
  notes            String?
  created_at       DateTime                @default(now())
  items            packing_receive_items[]

  @@index([created_at(sort: Desc)])
}

model packing_receive_items {
  id                 String           @id @default(uuid())
  packing_receive_id String
  variant_id         String
  quantity           Int
  packing_receive    packing_receives @relation(fields: [packing_receive_id], references: [id], onDelete: Cascade)
  variant            product_variants @relation(fields: [variant_id], references: [id])
}

model variant_inventory {
  id         String           @id @default(uuid())
  variant_id String           @unique
  quantity   Int              @default(0)
  updated_at DateTime         @default(now())
  variant    product_variants @relation(fields: [variant_id], references: [id])

  @@index([quantity(sort: Desc)])
}

model companies {
  id          String   @id @default(uuid())
  name        String   @unique
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  tasks       tasks[]
}

model tasks {
  id            String           @id @default(uuid())
  title         String
  description   String?
  
  area_id       String?
  area          Area?      @relation(fields: [area_id], references: [id])
  

  company_id    String?
  assignee_id   String?
  created_by    String
  status        String           @default("not_started")
  priority      String           @default("medium")
  due_date      DateTime?
  start_date    DateTime?
  completed_at  DateTime?
  estimated_hours Float?
  recurrence      String?
  tier            String?
  has_spawned_recurrence Boolean @default(false)
  created_at    DateTime         @default(now())
  updated_at    DateTime         @updatedAt
  subtasks      subtasks[]
  comments      task_comments[]
  time_logs     task_time_logs[]
  attachments   task_attachments[]
  company       companies?       @relation(fields: [company_id], references: [id])
  assignee      Employee?        @relation("task_assignee", fields: [assignee_id], references: [id])
  creator       Employee         @relation("task_creator", fields: [created_by], references: [id])
  notifications notifications[]

  @@index([status])
  @@index([assignee_id])
  @@index([priority])
  @@index([due_date])
  @@index([created_by])
  @@index([area_id])
  @@index([company_id])
}

model task_attachments {
  id          String   @id @default(uuid())
  task_id     String
  file_name   String
  file_url    String
  file_size   Int?
  file_type   String?
  uploaded_by String
  created_at  DateTime @default(now())
  
  task        tasks    @relation(fields: [task_id], references: [id], onDelete: Cascade)
  uploader    Employee @relation(fields: [uploaded_by], references: [id])

  @@index([task_id])
}

model subtasks {
  id           String   @id @default(uuid())
  task_id      String
  title        String
  is_completed Boolean  @default(false)
  created_at   DateTime @default(now())
  task         tasks    @relation(fields: [task_id], references: [id], onDelete: Cascade)

  @@index([task_id])
}

model task_comments {
  id          String    @id @default(uuid())
  task_id     String
  employee_id String
  content     String
  created_at  DateTime  @default(now())
  employee    Employee  @relation(fields: [employee_id], references: [id])
  task        tasks     @relation(fields: [task_id], references: [id], onDelete: Cascade)

  @@index([task_id])
  @@index([employee_id])
}

model notifications {
  id           String    @id @default(uuid())
  recipient_id String
  actor_id     String
  action_type  String
  task_id      String
  task_title   String
  created_at   DateTime  @default(now())
  read_at      DateTime?
  recipient    Employee  @relation("notification_recipient", fields: [recipient_id], references: [id])
  actor        Employee  @relation("notification_actor", fields: [actor_id], references: [id])
  task         tasks     @relation(fields: [task_id], references: [id], onDelete: Cascade)

  @@index([recipient_id, created_at(sort: Desc)])
  @@index([task_id])
}

model app_settings {
  key        String   @id
  value      String
  updated_at DateTime @default(now()) @updatedAt
}

model task_time_logs {
  id          String    @id @default(uuid())
  task_id     String
  employee_id String
  hours       Float
  notes       String?
  created_at  DateTime  @default(now())
  employee    Employee  @relation(fields: [employee_id], references: [id])
  task        tasks     @relation(fields: [task_id], references: [id], onDelete: Cascade)

  @@index([task_id])
  @@index([employee_id])
}

// Daily Command Center - Standalone Module

model DailyPlan {
  id             String         @id @default(uuid())
  employee_id    String
  plan_date      DateTime       @default(now())
  score          Int            @default(0) // Out of 10
  
  employee       Employee       @relation("employee_daily_plans", fields: [employee_id], references: [id])
  items          DailyItem[]
  blockers       DailyBlocker[]
  tomorrow_notes String[]       // Simple list for next day's prep
  
  created_at     DateTime       @default(now())
  updated_at     DateTime       @updatedAt

  @@unique([plan_date, employee_id])
  @@index([employee_id])
  @@index([plan_date])
  @@map("daily_plans")
}

model DailyItem {
  id              String    @id @default(uuid())
  daily_plan_id   String
  title           String
  tier            Int       // 1 = Move the Needle, 2 = Quick Wins
  biz             String    // 'S' = Sales, 'N' = Non-Sales
  status          String    @default("PENDING") // PENDING, COMPLETED, BLOCKED, ARCHIVED
  notes           String?   
  
  // Specific to Blocker/Carryover logic
  blocker_reason  String?   
  action_owner    String?   
  carryover_count Int       @default(0)
  
  daily_plan      DailyPlan @relation(fields: [daily_plan_id], references: [id], onDelete: Cascade)

  @@index([daily_plan_id])
  @@index([status])
  @@map("daily_items")
}

model DailyBlocker {
  id             String    @id @default(uuid())
  daily_plan_id  String
  blocker_text   String
  action_owner   String?   // Who needs to act
  status         String    @default("ACTIVE") // ACTIVE, RESOLVED
  
  daily_plan     DailyPlan @relation(fields: [daily_plan_id], references: [id], onDelete: Cascade)

  @@index([daily_plan_id])
  @@map("daily_blockers")
}

model test_table2 {
  id         String   @id @default(uuid())
  name       String
  created_at DateTime @default(now())
}

model Area {
  id          String   @id @default(uuid())
  name        String   @unique
  color       String   @default("#6366f1")
  description String?
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  
  tasks       tasks[]
  
  @@index([name])
  @@map("areas")
}