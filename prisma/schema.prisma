generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model roles {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())

  employees employees[]

  @@index([name])
  @@index([is_active])
}

model employees {
  id             String           @id
  name           String
  email          String           @unique
  is_active      Boolean          @default(true)
  created_at     DateTime         @default(now())
  updated_at     DateTime         @updatedAt
  role_id        String?
  role           roles?           @relation(fields: [role_id], references: [id])
  comments       task_comments[]
  time_logs      task_time_logs[]
  assigned_tasks tasks[]          @relation("task_assignee")
  created_tasks  tasks[]          @relation("task_creator")

  @@index([email])
  @@index([role_id])
  @@index([is_active])
}

model raw_materials {
  id           String                @id @default(uuid())
  name         String
  quantity     Float
  price_per_kg Float?
  unit         String                @default("kg")
  logs         raw_material_logs[]
  receivings   receiving_materials[]

  @@index([name])
}

model receiving_materials {
  id              String        @id @default(uuid())
  raw_material_id String
  quantity        Float
  rate            Float?
  supplier        String
  date            DateTime      @default(now())
  notes           String?
  unit            String        @default("kg")
  raw_material    raw_materials @relation(fields: [raw_material_id], references: [id])

  @@index([raw_material_id])
  @@index([date(sort: Desc)])
}

model flavors {
  id                String              @id @default(uuid())
  name              String
  short_code        String              @default("XX")
  is_active         Boolean             @default(true)
  created_at        DateTime            @default(now())
  ingredients       String?
  batches           batches[]
  finished_products finished_products[]
  product_flavors   product_flavors[]
  variants          product_variants[]
}

model products {
  id              String             @id @default(uuid())
  name            String
  description     String?
  is_active       Boolean            @default(true)
  created_at      DateTime           @default(now())
  product_flavors product_flavors[]
  variants        product_variants[]
}

model product_variants {
  id            String                  @id @default(uuid())
  product_id    String
  size_id       String
  price         Float                   @default(0)
  sku           String                  @unique
  is_active     Boolean                 @default(false)
  created_at    DateTime                @default(now())
  description   String?
  flavor_id     String
  receive_items packing_receive_items[]
  flavor        flavors                 @relation(fields: [flavor_id], references: [id])
  product       products                @relation(fields: [product_id], references: [id], onDelete: Cascade)
  size          sizes                   @relation(fields: [size_id], references: [id])
  inventory     variant_inventory?

  @@unique([product_id, flavor_id, size_id])
  @@index([product_id])
  @@index([is_active])
}

model product_flavors {
  id         String   @id @default(uuid())
  product_id String
  flavor_id  String
  flavor     flavors  @relation(fields: [flavor_id], references: [id])
  product    products @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@unique([product_id, flavor_id])
}

model sizes {
  id         String             @id @default(uuid())
  size       String
  unit       String             @default("kg")
  pack_type  String
  is_active  Boolean            @default(true)
  created_at DateTime           @default(now())
  variants   product_variants[]
}

model transactions {
  id           String   @id @default(uuid())
  type         String
  amount       Float
  date         DateTime @default(now())
  reference_id String?
  person       String?
  note         String?
  created_at   DateTime @default(now())

  @@index([type])
  @@index([date(sort: Desc)])
}

model batches {
  id              String   @id @default(uuid())
  batch_id        String   @unique
  date            DateTime @default(now())
  logged_by       String
  flavor_id       String
  leaves_in       Float
  powder_out      Float
  waste_loss      Float
  yield_percent   Float
  quality_check   Boolean  @default(false)
  status          String
  notes           String?
  created_at      DateTime @default(now())
  raw_material_id String?
  flavor          flavors  @relation(fields: [flavor_id], references: [id])

  @@index([status])
  @@index([created_at(sort: Desc)])
  @@index([flavor_id])
}

model raw_material_logs {
  id              String        @id @default(uuid())
  raw_material_id String
  quantity        Float
  type            String
  reference_id    String?
  created_at      DateTime      @default(now())
  raw_material    raw_materials @relation(fields: [raw_material_id], references: [id])

  @@index([raw_material_id])
  @@index([created_at(sort: Desc)])
}

model finished_products {
  id              String   @id @default(uuid())
  flavor_id       String
  quantity        Float
  batch_reference String?
  created_at      DateTime @default(now())
  flavor          flavors  @relation(fields: [flavor_id], references: [id])

  @@index([created_at(sort: Desc)])
  @@index([flavor_id])
}

model packing_logs {
  id               String   @id @default(uuid())
  third_party_name String
  bag_size         Int
  bag_count        Int
  total_kg         Float
  created_at       DateTime @default(now())

  @@index([created_at(sort: Desc)])
}

model powder_stock {
  id                 Int      @id @default(autoincrement())
  total_from_batches Float
  total_sent         Float
  available          Float
  updated_at         DateTime @default(now())
}

model packing_receives {
  id               String                  @id @default(uuid())
  third_party_name String
  notes            String?
  created_at       DateTime                @default(now())
  items            packing_receive_items[]

  @@index([created_at(sort: Desc)])
}

model packing_receive_items {
  id                 String           @id @default(uuid())
  packing_receive_id String
  variant_id         String
  quantity           Int
  packing_receive    packing_receives @relation(fields: [packing_receive_id], references: [id], onDelete: Cascade)
  variant            product_variants @relation(fields: [variant_id], references: [id])
}

model variant_inventory {
  id         String           @id @default(uuid())
  variant_id String           @unique
  quantity   Int              @default(0)
  updated_at DateTime         @default(now())
  variant    product_variants @relation(fields: [variant_id], references: [id])

  @@index([quantity(sort: Desc)])
}

model tasks {
  id           String           @id @default(uuid())
  title        String
  description  String?
  assignee_id  String?
  created_by   String
  status       String           @default("not_started")
  priority     String           @default("medium")
  due_date     DateTime?
  start_date   DateTime?
  completed_at DateTime?
  created_at   DateTime         @default(now())
  updated_at   DateTime         @updatedAt
  subtasks     subtasks[]
  comments     task_comments[]
  time_logs    task_time_logs[]
  assignee     employees?       @relation("task_assignee", fields: [assignee_id], references: [id])
  creator      employees        @relation("task_creator", fields: [created_by], references: [id])

  @@index([status])
  @@index([assignee_id])
  @@index([priority])
  @@index([due_date])
  @@index([created_by])
}

model subtasks {
  id           String   @id @default(uuid())
  task_id      String
  title        String
  is_completed Boolean  @default(false)
  created_at   DateTime @default(now())
  task         tasks    @relation(fields: [task_id], references: [id], onDelete: Cascade)

  @@index([task_id])
}

model task_comments {
  id          String    @id @default(uuid())
  task_id     String
  employee_id String
  content     String
  created_at  DateTime  @default(now())
  employee    employees @relation(fields: [employee_id], references: [id])
  task        tasks     @relation(fields: [task_id], references: [id], onDelete: Cascade)

  @@index([task_id])
  @@index([employee_id])
}

model task_time_logs {
  id          String    @id @default(uuid())
  task_id     String
  employee_id String
  hours       Float
  notes       String?
  created_at  DateTime  @default(now())
  employee    employees @relation(fields: [employee_id], references: [id])
  task        tasks     @relation(fields: [task_id], references: [id], onDelete: Cascade)

  @@index([task_id])
  @@index([employee_id])
}
